# API Configuration
VITE_API_BASE_URL=https://your-api-gateway.execute-api.us-east-1.amazonaws.com/prod
VITE_API_KEY=your_api_key_here

# WebSocket URL for real-time updates (from CDK output WebSocketUrl)
VITE_WS_URL=wss://YOUR_WS_API_ID.execute-api.us-east-1.amazonaws.com/prod

# Monitoring Configuration
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_ENVIRONMENT=development
VITE_SENTRY_SAMPLE_RATE=1.0
VITE_VERSION=3.0.0
