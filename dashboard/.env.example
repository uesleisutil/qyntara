# AWS Configuration
REACT_APP_AWS_REGION=us-east-1
REACT_APP_S3_BUCKET=b3tr-YOUR_ACCOUNT_ID-us-east-1

# AWS Credentials (para desenvolvimento local)
# Em produção, use IAM roles do Amplify
REACT_APP_AWS_ACCESS_KEY_ID=your_access_key_here
REACT_APP_AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Monitoring Configuration
# Sentry DSN for error tracking (Req 76.5)
REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry environment (development, staging, production)
REACT_APP_ENVIRONMENT=development

# Sentry sample rate (0.0 to 1.0)
REACT_APP_SENTRY_SAMPLE_RATE=1.0

# Application version
REACT_APP_VERSION=2.0.3