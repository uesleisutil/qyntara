# Example local environment configuration for B3 Tactical Ranking Dashboard
# Copy this file to .env.local and fill in your values

# ⚠️ SECURITY WARNING: NEVER commit real AWS credentials!
# This file is for documentation only. Real credentials should be:
# 1. Stored in AWS Secrets Manager
# 2. Used via AWS CLI profiles
# 3. Obtained via temporary credentials (STS)

REACT_APP_AWS_REGION=us-east-1

# AWS Credentials (DO NOT use real credentials here)
# Instead, use one of these methods:
# 
# Method 1: AWS CLI Profile (RECOMMENDED)
# aws configure --profile b3tr-dashboard
# export AWS_PROFILE=b3tr-dashboard
#
# Method 2: Temporary Credentials
# aws sts get-session-token --duration-seconds 3600
#
# Method 3: IAM Role (for EC2/ECS)
# No credentials needed - uses instance role

# REACT_APP_AWS_ACCESS_KEY_ID=NEVER_PUT_REAL_KEY_HERE
# REACT_APP_AWS_SECRET_ACCESS_KEY=NEVER_PUT_REAL_SECRET_HERE

# S3 Bucket
REACT_APP_S3_BUCKET=b3tr-ACCOUNT_ID-REGION

# API Base URL (optional)
# REACT_APP_API_BASE_URL=/api
